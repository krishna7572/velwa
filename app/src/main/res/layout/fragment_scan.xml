<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Scan Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nearby Devices"
            android:textSize="20sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ProgressBar
            android:id="@+id/scanProgress"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:indeterminateTint="@color/neon_blue"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scan button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/scanBtn"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:text="🔍 Scan Shuru Karo"
        android:textSize="15sp"
        android:textColor="@color/text_primary"
        app:backgroundTint="@color/neon_blue"
        app:cornerRadius="14dp"
        app:icon="@drawable/ic_scan"
        app:iconTint="@color/text_primary" />

    <!-- Results -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/scanRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="80dp" />

    <TextView
        android:id="@+id/scanEmptyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Scan karo — nearby Bluetooth devices yahan dikhenge"
        android:textSize="13sp"
        android:textColor="@color/text_tertiary"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="visible" />

</LinearLayout>
