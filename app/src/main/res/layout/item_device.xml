<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    style="@style/VelwaCard"
    app:cardCornerRadius="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Device Icon with neon glow bg -->
        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_icon_circle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/deviceIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:tint="@color/neon_blue"
                android:src="@drawable/ic_device_earbuds" />
        </FrameLayout>

        <!-- Connected Pulse -->
        <View
            android:id="@+id/connectedPulse"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_pulse_dot"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/iconContainer"
            app:layout_constraintEnd_toEndOf="@id/iconContainer" />

        <!-- Device Name -->
        <TextView
            android:id="@+id/deviceName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Galaxy Buds Pro"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="14dp"
            app:layout_constraintTop_toTopOf="@id/iconContainer"
            app:layout_constraintStart_toEndOf="@id/iconContainer"
            app:layout_constraintEnd_toStartOf="@id/actionBtn" />

        <!-- Connection Status -->
        <TextView
            android:id="@+id/connectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Connected"
            android:textSize="11sp"
            android:textColor="@color/neon_green"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/deviceName"
            app:layout_constraintStart_toStartOf="@id/deviceName" />

        <!-- Device Type Chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/deviceTypeChip"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:text="Earbuds"
            android:textSize="10sp"
            android:textColor="@color/neon_purple"
            app:chipBackgroundColor="@color/neon_purple_dim"
            app:chipCornerRadius="6dp"
            app:chipStrokeWidth="0dp"
            app:chipMinHeight="24dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/connectionStatus"
            app:layout_constraintStart_toStartOf="@id/deviceName" />

        <!-- Address -->
        <TextView
            android:id="@+id/deviceAddress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="00:11:22:33:44"
            android:textSize="10sp"
            android:textColor="@color/text_tertiary"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/deviceTypeChip"
            app:layout_constraintStart_toStartOf="@id/deviceName"
            app:layout_constraintEnd_toStartOf="@id/actionBtn" />

        <!-- Battery Group -->
        <LinearLayout
            android:id="@+id/batteryGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="visible"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/deviceAddress"
            app:layout_constraintStart_toStartOf="@id/deviceName">

            <ImageView
                android:id="@+id/batteryIcon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_battery_full"
                android:tint="@color/neon_green" />

            <TextView
                android:id="@+id/batteryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="85%"
                android:textSize="10sp"
                android:textColor="@color/neon_green"
                android:layout_marginStart="3dp" />
        </LinearLayout>

        <!-- Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/actionBtn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Connect"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/neon_blue"
            app:cornerRadius="10dp"
            android:paddingHorizontal="14dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/favoriteIcon"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Favorite Icon -->
        <ImageView
            android:id="@+id/favoriteIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_favorite"
            android:tint="@color/text_secondary"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
