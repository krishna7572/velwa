<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Velwa" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_blue</item>
        <item name="colorPrimaryVariant">@color/bg_primary</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/neon_purple</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorBackground">@color/bg_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/error_red</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_secondary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="materialButtonStyle">@style/Widget.Velwa.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.Velwa.BottomNav</item>
    </style>

    <style name="Theme.Velwa.Splash" parent="Theme.Velwa">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <style name="Widget.Velwa.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/neon_blue</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="Widget.Velwa.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/bg_secondary</item>
        <item name="itemIconTint">@color/nav_tint_selector</item>
        <item name="itemTextColor">@color/nav_tint_selector</item>
        <item name="itemActiveIndicatorColor">@color/neon_blue_dim</item>
    </style>

    <style name="TextAppearance.Velwa.Title" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <style name="TextAppearance.Velwa.Body" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="VelwaCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1dp</item>
    </style>

</resources>
